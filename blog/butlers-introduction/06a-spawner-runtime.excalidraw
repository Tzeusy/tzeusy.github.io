    {
      "type": "text",
      "id": "mcp_evidence_txt",
      "x": 900,
      "y": 263,
      "width": 680,
      "height": 110,
      "text": "mcp_url = runtime_mcp_url(config.port)          # e.g. http://127.0.0.1:8000/mcp\nmcp_url = _append_runtime_session_query(mcp_url, session_id)\nmcp_servers = { config.name: { \"url\": mcp_url } }\n\nenv = await _build_env(config, module_creds_env, credential_store)\n# env keys: PATH, ANTHROPIC_API_KEY, OPENAI_API_KEY, + declared vars only",
      "originalText": "mcp_url = runtime_mcp_url(config.port)          # e.g. http://127.0.0.1:8000/mcp\nmcp_url = _append_runtime_session_query(mcp_url, session_id)\nmcp_servers = { config.name: { \"url\": mcp_url } }\n\nenv = await _build_env(config, module_creds_env, credential_store)\n# env keys: PATH, ANTHROPIC_API_KEY, OPENAI_API_KEY, + declared vars only",
