    {
      "type": "text",
      "id": "module_contract_text",
      "x": 976,
      "y": 1052,
      "width": 348,
      "height": 260,
      "text": "class Module(ABC):\n  name: str\n  config_schema: BaseModel\n  dependencies: list[str]\n\n  async def register_tools(\n    mcp, config, db\n  ) -> None\n\n  def migration_revisions(\n  ) -> str | None\n\n  async def on_startup(\n    config, db, credential_store\n  ) -> None\n\n  async def on_shutdown() -> None\n\n  def tool_metadata(\n  ) -> dict[str, ToolMeta]\n\n# deps resolved via topological sort",
      "originalText": "class Module(ABC):\n  name: str\n  config_schema: BaseModel\n  dependencies: list[str]\n\n  async def register_tools(\n    mcp, config, db\n  ) -> None\n\n  def migration_revisions(\n  ) -> str | None\n\n  async def on_startup(\n    config, db, credential_store\n  ) -> None\n\n  async def on_shutdown() -> None\n\n  def tool_metadata(\n  ) -> dict[str, ToolMeta]\n\n# deps resolved via topological sort",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#22c55e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
