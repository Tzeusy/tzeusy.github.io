    {
      "type": "text",
      "id": "comp_sm2_detail_lbl",
      "x": 770,
      "y": 398,
      "width": 180,
      "height": 64,
      "text": "SM-2 Formula\nI(n) = I(n-1) * EF\nEF = max(1.3, EF + (0.1 - (5-q)*(0.08+\n(5-q)*0.02)))   q: 0-5",
      "originalText": "SM-2 Formula\nI(n) = I(n-1) * EF\nEF = max(1.3, EF + (0.1 - (5-q)*(0.08+\n(5-q)*0.02)))   q: 0-5",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "middle",
      "strokeColor": "#22c55e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 20082,
      "version": 1,
