    {
      "type": "text",
      "id": "approval_detail_body",
      "x": 80,
      "y": 784,
      "width": 500,
      "height": 168,
      "text": "Triggers when action is potentially disruptive:\n\n  \u2022 Changing thermostat set point\n  \u2022 Toggling devices (lights, locks, switches)\n  \u2022 Activating or disabling automations\n  \u2022 Arming / disarming security system\n\nFlow:\n  1. Butler proposes action via notify()\n  2. User reacts: \u2705 approve  |  \u274c deny\n  3. On approve \u2192 ha_call_service() executes\n  4. On deny \u2192 action skipped, preference noted\n  5. memory_store_fact: outcome logged",
      "originalText": "Triggers when action is potentially disruptive:\n\n  \u2022 Changing thermostat set point\n  \u2022 Toggling devices (lights, locks, switches)\n  \u2022 Activating or disabling automations\n  \u2022 Arming / disarming security system\n\nFlow:\n  1. Butler proposes action via notify()\n  2. User reacts: \u2705 approve  |  \u274c deny\n  3. On approve \u2192 ha_call_service() executes\n  4. On deny \u2192 action skipped, preference noted\n  5. memory_store_fact: outcome logged",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#374151",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
