    {
      "type": "text",
      "id": "contacts_table_cols",
      "x": 88,
      "y": 548,
      "width": 364,
      "height": 150,
      "text": "id          UUID PK\nname        TEXT\nroles       TEXT[]   -- e.g. ['owner']\nentity_id   UUID FK→memory.entities\nmetadata    JSONB\ncreated_at  TIMESTAMPTZ\n\nUNIQUE INDEX (true) WHERE 'owner' = ANY(roles)\n-- enforces at most one owner contact",
      "originalText": "id          UUID PK\nname        TEXT\nroles       TEXT[]   -- e.g. ['owner']\nentity_id   UUID FK→memory.entities\nmetadata    JSONB\ncreated_at  TIMESTAMPTZ\n\nUNIQUE INDEX (true) WHERE 'owner' = ANY(roles)\n-- enforces at most one owner contact",
