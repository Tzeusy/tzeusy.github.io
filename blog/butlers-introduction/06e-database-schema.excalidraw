    {
      "type": "text",
      "id": "owner_bootstrap_body",
      "x": 888,
      "y": 548,
      "width": 244,
      "height": 150,
      "text": "On daemon startup:\n\n1. Check for existing owner\n   contact in shared.contacts\n   WHERE 'owner' = ANY(roles)\n\n2. If missing, INSERT owner\n   with name=\"Owner\",\n   roles = ['owner']\n\nPartial unique index prevents\nduplicate owner rows.\n\n(contact_info rows linked\nseparately via credential store)",
      "originalText": "On daemon startup:\n\n1. Check for existing owner\n   contact in shared.contacts\n   WHERE 'owner' = ANY(roles)\n\n2. If missing, INSERT owner\n   with name=\"Owner\",\n   roles = ['owner']\n\nPartial unique index prevents\nduplicate owner rows.\n\n(contact_info rows linked\nseparately via credential store)",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#065f46",
      "backgroundColor": "transparent",
