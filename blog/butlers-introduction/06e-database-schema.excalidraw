    {
      "type": "text",
      "id": "mig_alembic_note",
      "x": 920,
      "y": 998,
      "width": 220,
      "height": 140,
      "text": "All chains run against\nthe same 'butlers' DB.\n\nAlembic tracks each chain\nindependently in\nalembic_version table\n(version_table_schema\nsets which schema it\nlands in per butler run).",
      "originalText": "All chains run against\nthe same 'butlers' DB.\n\nAlembic tracks each chain\nindependently in\nalembic_version table\n(version_table_schema\nsets which schema it\nlands in per butler run).",
